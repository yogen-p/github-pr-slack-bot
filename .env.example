# ── Claude AI ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...    # Enables natural language @mention responses

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_CHANNEL_ID=C...           # Right-click the channel in Slack → Copy channel ID

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...            # Personal access token — needs: repo, read:org
GITHUB_WEBHOOK_SECRET=...       # Secret you set when creating the webhook in GitHub
GITHUB_REPO_OWNER=your-org
GITHUB_REPO_NAME=your-repo

# ── Customisation (all optional) ──────────────────────────────────────────────

# Slack emoji name (without colons) reacted to the PR message when approved.
# Default: white_check_mark
# EMOJI_APPROVED=white_check_mark

# Slack emoji name reacted when a reviewer requests changes.
# Default: rabbit
# EMOJI_CHANGES_REQUESTED=rabbit

# Text prepended to every PR notification. Supports Slack mention syntax.
# <!here> = notify online members, <!channel> = notify everyone, leave empty to disable.
# Default: <!here>
# MENTION_PREFIX=<!here>

# Comma-separated "Name:github_username" pairs so the bot understands real names.
# Example: TEAMMATES=Aidan:adlee,Sarah:schen,Mike:mwilson
# TEAMMATES=

PORT=3000